{
  "name": "rankings",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:reset": "rm -f .wrangler/state/v3/d1/*/*.sqlite* 2>/dev/null; true",
    "db:schema": "wrangler d1 execute rankings --local --file=schema/schema.sql",
    "catalog:build": "bun run scripts/build-catalog-sql.ts",
    "catalog:load": "wrangler d1 execute rankings --local --file=schema/seed-catalog.sql",
    "rankings:build": "bun run scripts/backfill-txt.ts",
    "rankings:load": "wrangler d1 execute rankings --local --file=schema/seed-rankings.sql",
    "events:build": "bun run scripts/build-events-sql.ts",
    "events:load": "wrangler d1 execute rankings --local --file=schema/seed-events.sql",
    "test:matcher": "bun run scripts/test-matcher.ts",
    "seed": "bun run catalog:build && bun run events:build && bun run rankings:build && bun run db:schema && bun run catalog:load && bun run events:load && bun run rankings:load",
    "local:setup": "bun run catalog:build && bun run events:build && bun run rankings:build && bun run scripts/local-setup.ts",
    "dev": "bun run scripts/dev-server.ts",
    "dev:wrangler": "wrangler pages dev . --d1=DB=rankings --port 8788",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.112.0"
  }
}
