{
  "comment": "Deploy code — Cloudflare Workers globals. Bun/Node scripts use tsconfig.scripts.json.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  },
  "include": ["functions", "src"],
  "exclude": ["src/catalog-fs.ts"]
}
